# =============================================
#  SUPER LOTTO NUMBER — .gitignore
#  Frontend + Backend + DB 통합 개발 대비
# =============================================


# ── 환경변수 / 시크릿 (절대 커밋 금지) ──────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.*.local
*.pem
*.key
*.cert
secrets/
config/secrets.*


# ── Node.js / npm / yarn / pnpm ─────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
package-lock.json
yarn.lock
pnpm-lock.yaml
.npm
.yarn/


# ── 빌드 / 번들 출력 ────────────────────────
dist/
build/
out/
.next/
.nuxt/
.svelte-kit/
.vite/
.cache/
public/build/


# ── Python ──────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
.venv/
env/
ENV/
*.egg-info/
dist/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml


# ── Java / Spring Boot ──────────────────────
*.class
*.jar
*.war
*.ear
target/
.mvn/
mvnw
gradlew
.gradle/
build/


# ── 데이터베이스 ─────────────────────────────
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal
*.sql.bak
dump.sql
dumps/
db_backup/
data/


# ── 로그 ─────────────────────────────────────
logs/
*.log
*.log.*


# ── OS 생성 파일 ─────────────────────────────
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*


# ── IDE / 에디터 ─────────────────────────────
# VSCode (팀 공유 설정은 남기고 개인 설정만 제외)
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
*.code-workspace

# JetBrains (IntelliJ, WebStorm, PyCharm 등)
.idea/
*.iml
*.ipr
*.iws

# Vim / Emacs
*.swp
*.swo
*~
\#*\#


# ── 테스트 / 커버리지 ────────────────────────
coverage/
.nyc_output/
test-results/
playwright-report/
cypress/videos/
cypress/screenshots/


# ── 임시 / 기타 ──────────────────────────────
tmp/
temp/
*.tmp
*.bak
*.orig
*.rej
.turbo/
.parcel-cache/

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
!.env.example
